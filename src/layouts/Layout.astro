---
import { languagesList } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';

const pathPage = (globalThis as any).BASE_URL;
const currentLang = Astro.currentLocale || "en";
const translations = useTranslations(currentLang as keyof typeof languagesList);

// Build absolute URLs for SEO
const siteOrigin = Astro.url.origin;
const canonicalURL = Astro.url.href;
const enURL = `${siteOrigin}${pathPage}en/`;
const esURL = `${siteOrigin}${pathPage}es/`;
const ogImageURL = `${siteOrigin}${pathPage}images/carlos-velasquez.jpg`;
const siteURL = `${siteOrigin}${pathPage}`;

// Schema.org structured data
const schemaJSON = JSON.stringify({
	"@context": "https://schema.org",
	"@type": "Person",
	"name": "Carlos Velasquez",
	"jobTitle": "Full Stack Developer",
	"url": siteURL,
	"image": ogImageURL,
	"sameAs": [
		"https://github.com/cvelasquezr8",
		"https://linkedin.com/in/cvelasquezr8",
		"https://roadmap.sh/u/cvelasquezr8",
		"https://hackerrank.com/profile/cvelasquezr8",
		"https://leetcode.com/u/cvelasquezr8/"
	],
	"description": translations('index.description'),
	"knowsAbout": ["Node.js", "NestJS", "React", "Next.js", "PostgreSQL", "TypeScript", "Docker", "REST APIs"]
});
---

<html lang={currentLang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="robots" content="index, follow" />
		<meta name="theme-color" content="#0A0B14" />

		<!-- Favicon -->
		<link rel="icon" type="image/x-icon" href={`${pathPage}images/website.ico`} />
		<link rel="apple-touch-icon" href={`${pathPage}images/website.ico`} />

		<!-- Preload LCP hero image -->
		<link rel="preload" as="image" href={`${pathPage}images/carlos-velasquez.jpg`} />

		<!-- Preload Roboto 400 (body text critical for FCP) — Merriweather excluded to avoid LCP bandwidth competition -->
		<link rel="preload" as="font" type="font/woff2" crossorigin href={`${pathPage}fonts/KFOMCnqEu92Fr1ME7kSn66aGLdTylUAMQXC89YmC2DPNWubEbWmT.woff2`} />

		<!-- Canonical & Hreflang -->
		<link rel="canonical" href={canonicalURL} />
		<link rel="alternate" hreflang="en" href={enURL} />
		<link rel="alternate" hreflang="es" href={esURL} />
		<link rel="alternate" hreflang="x-default" href={enURL} />

		<!-- Primary Meta Tags -->
		<title>{translations('index.title')}</title>
		<meta name="title" content={translations('index.title')} />
		<meta name="description" content={translations('index.description')} />
		<meta name="author" content="Carlos Velasquez" />
		<meta name="keywords" content={translations('index.keywords')} />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={translations('index.title')} />
		<meta property="og:description" content={translations('index.description')} />
		<meta property="og:image" content={ogImageURL} />
		<meta property="og:image:alt" content="Carlos Velasquez - Full Stack Developer" />
		<meta property="og:locale" content={currentLang === 'es' ? 'es_ES' : 'en_US'} />
		<meta property="og:site_name" content="Carlos Velasquez Portfolio" />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={canonicalURL} />
		<meta property="twitter:title" content={translations('index.title')} />
		<meta property="twitter:description" content={translations('index.description')} />
		<meta property="twitter:image" content={ogImageURL} />
		<meta property="twitter:image:alt" content="Carlos Velasquez - Full Stack Developer" />

		<!-- Schema.org JSON-LD -->
		<script type="application/ld+json" is:inline set:html={schemaJSON} />

		<!-- Google Analytics — loaded during browser idle time to avoid blocking -->
		<script is:inline>
		  window.dataLayer = window.dataLayer || [];
		  function gtag(){window.dataLayer.push(arguments);}
		  gtag('js', new Date());
		  gtag('config', 'G-SJ8RXQ8BMG');
		  (window.requestIdleCallback || function(cb){ setTimeout(cb, 2000); })(function() {
		    var s = document.createElement('script');
		    s.async = true;
		    s.src = 'https://www.googletagmanager.com/gtag/js?id=G-SJ8RXQ8BMG';
		    document.head.appendChild(s);
		  });
		</script>

		<!-- Fonts — async load to avoid render blocking (single tag pattern) -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			rel="preload"
			href="https://fonts.googleapis.com/css2?family=Audiowide&display=swap"
			as="style"
			onload="this.onload=null;this.rel='stylesheet'"
		/>
		<noscript>
			<link href="https://fonts.googleapis.com/css2?family=Audiowide&display=swap" rel="stylesheet" />
		</noscript>

		<!-- Theme Script -->
		<script>
			const THEME_KEY = 'portfolio-theme';
			const THEMES = {
				DARK: 'dark',
			};

			function applyTheme(theme: any) {
				const root = document.documentElement;
				root.classList.remove(THEMES.DARK);
				root.classList.add(theme);
				// CSS variables are already defined in :root in the stylesheet — no setProperty needed
			}

			// Initialize theme
			const savedTheme = localStorage.getItem(THEME_KEY) || THEMES.DARK;
			applyTheme(savedTheme);

			(window as any).setTheme = function (theme: any) {
				localStorage.setItem(THEME_KEY, theme);
				applyTheme(theme);
			};

			// Add dynamic stars — use % units to avoid any layout reads (forced reflow prevention)
			document.addEventListener('DOMContentLoaded', function() {
				const starsWrapper = document.querySelector('.stars-wrapper') as any;
				if (starsWrapper) {
					const fragment = document.createDocumentFragment();
					for (let i = 0; i < 20; i++) {
						const star = document.createElement('div');
						star.className = 'shooting-star';
						star.style.cssText = `left:${Math.random() * 100}%;top:${Math.random() * 100}%;animation-delay:${Math.random() * 2}s`;
						fragment.appendChild(star);
					}
					starsWrapper.appendChild(fragment);
				}

				const sections = document.querySelectorAll(".section-fade");
				const observer = new IntersectionObserver((entries) => {
					entries.forEach((entry) => {
						if (entry.isIntersecting) {
							entry.target.classList.add("show");
						} else {
							entry.target.classList.remove("show");
						}
					});
				}, { threshold: 0.2 });

				sections.forEach((section) => observer.observe(section));
			});
		</script>
	</head>
	<body class="theme-transition">
		<div class="stars-wrapper">
			<div id="stars"></div>
			<div id="stars2"></div>
			<div id="stars3"></div>
			<div id="stars4"></div>
			<div id="stars5"></div>
			<div class="nebula"></div>
		</div>
		<slot />
	</body>
</html>
